            "grammar": {
                "tips": [
                    {
                        "label": "詢問單數物品的主人",
                        "text": "用 Whose + 單數名詞 + is this? 來問「這是誰的___？」，回答用 It's + 所有格 + 名詞。"
                    },
                    {
                        "label": "詢問複數物品的主人",
                        "text": "用 Whose + 複數名詞 + are these? 來問「這些是誰的___？」，回答用 They're + 所有格 + 名詞。"
                    },
                    {
                        "label": "常用所有格",
                        "text": "my（我的）、your（你的）、his（他的）、her（她的）、their（他們的）、our（我們的）"
                    }
                ],
                "notes": [
                    {
                        "title": "Whose 的用法",
                        "rule": "Whose 用來詢問物品屬於誰，等於「誰的」",
                        "description": "Whose 放在句首，後面接名詞，再接動詞。單數名詞用 is，複數名詞用 are。",
                        "examples": [
                            "Whose backpack is this? → It's his backpack.",
                            "Whose glasses are these? → They're her glasses.",
                            "Whose workbook is this? → It's my workbook.",
                            "Whose shoes are these? → They're his shoes."
                        ]
                    },
                    {
                        "title": "is this vs. are these",
                        "rule": "單數名詞搭配 is this，複數名詞搭配 are these",
                        "description": "glasses 和 shoes 永遠是複數，必須用 are these 來問。其他如 backpack、cap、lunchbox、umbrella、water bottle、workbook 是單數，用 is this 來問。",
                        "examples": [
                            "Whose cap is this?（cap 單數）",
                            "Whose lunchbox is this?（lunchbox 單數）",
                            "Whose glasses are these?（glasses 永遠複數）",
                            "Whose shoes are these?（shoes 永遠複數）"
                        ]
                    },
                    {
                        "title": "回答的句型",
                        "rule": "單數用 It's，複數用 They're",
                        "description": "回答 Whose 問句時，單數物品用 It's + 所有格 + 名詞，複數物品用 They're + 所有格 + 名詞。It's = It is，They're = They are。",
                        "examples": [
                            "It's her umbrella.（雨傘是單數）",
                            "It's his cap.（帽子是單數）",
                            "They're my glasses.（眼鏡是複數）",
                            "They're his shoes.（鞋子是複數）"
                        ]
                    }
